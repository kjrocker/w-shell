#!/usr/bin/env bash
set -euo pipefail

VERSION="0.0.1"
STATE_DIR="${W_STATE_DIR:-${HOME}/.local/state/w}"

# --- Project discovery ---

_w_find_root() {
  git rev-parse --show-toplevel 2>/dev/null || { echo "Not inside a git repository" >&2; exit 1; }
}

_w_project_name() {
  basename "$1"
}

_w_parent_dir() {
  dirname "$1"
}

_w_find_main_worktree() {
  local output
  output=$(git worktree list 2>/dev/null) || { echo "Not inside a git repository" >&2; exit 1; }
  echo "$output" | head -1 | awk '{print $1}'
}

# --- Subshell ---

_w_spawn_subshell() {
  local path="$1" root="$2" name="$3" slot="$4"
  if [[ -n "${W_WORKTREE:-}" ]]; then
    echo "Already in worktree '$W_WORKTREE'. Type 'exit' to leave first." >&2
    return 1
  fi
  local env_args=()
  local env_lines
  env_lines="$(_w_build_env "$root" "$name" "$slot")"
  if [[ -n "$env_lines" ]]; then
    while IFS='=' read -r key val; do
      env_args+=("$key=$val")
    done <<< "$env_lines"
  fi
  env_args+=("W_WORKTREE=$name" "W_PROJECT=$(_w_project_name "$root")" "W_ROOT=$root")
  cd "$path" && exec env "${env_args[@]}" "${SHELL:-/bin/bash}"
}

# --- Color helpers ---

_w_use_color() {
  [[ -z "${NO_COLOR:-}" ]] && [[ -t 2 ]]
}

_w_color() {
  local code="$1" text="$2"
  if _w_use_color; then
    printf '%b%s\e[0m' "$code" "$text"
  else
    printf '%s' "$text"
  fi
}

_w_bold()       { _w_color '\e[1m' "$1"; }
_w_green()      { _w_color '\e[32m' "$1"; }
_w_red()        { _w_color '\e[31m' "$1"; }
_w_yellow()     { _w_color '\e[33m' "$1"; }
_w_cyan()       { _w_color '\e[36m' "$1"; }
_w_dim()        { _w_color '\e[2m' "$1"; }
_w_bold_green() { _w_color '\e[1m\e[32m' "$1"; }

# --- Worktree parsing ---

_w_parse_worktrees() {
  local root="$1"
  git -C "$root" worktree list --porcelain | awk '
    /^worktree / { path = substr($0, 10) }
    /^HEAD /     { sha = $2 }
    /^branch /   { branch = $2; sub(/^refs\/heads\//, "", branch) }
    /^bare$/     { state = "bare" }
    /^detached$/ { state = "detached" }
    /^$/         {
      if (path != "") {
        if (state == "") state = "normal"
        if (branch == "") branch = ""
        printf "%s\t%s\t%s\t%s\n", path, branch, sha, state
        path = ""; branch = ""; sha = ""; state = ""
      }
    }
    END {
      if (path != "") {
        if (state == "") state = "normal"
        printf "%s\t%s\t%s\t%s\n", path, branch, sha, state
      }
    }
  '
}

_w_worktree_dirty() {
  local path="$1"
  [[ -n "$(git -C "$path" status --porcelain 2>/dev/null)" ]]
}

_w_worktree_dirty_count() {
  local path="$1"
  local output
  output="$(git -C "$path" status --porcelain 2>/dev/null)" || { echo 0; return; }
  if [[ -z "$output" ]]; then
    echo 0
  else
    echo "$output" | wc -l | tr -d ' '
  fi
}

_w_worktree_ahead_behind() {
  local path="$1"
  local output
  output="$(git -C "$path" rev-list --left-right --count HEAD...@{upstream} 2>/dev/null)" || { echo ""; return; }
  local ahead behind
  ahead="$(echo "$output" | awk '{print $1}')"
  behind="$(echo "$output" | awk '{print $2}')"
  local parts=()
  [[ "$ahead" -gt 0 ]] 2>/dev/null && parts+=("ahead $ahead")
  [[ "$behind" -gt 0 ]] 2>/dev/null && parts+=("behind $behind")
  if [[ ${#parts[@]} -gt 0 ]]; then
    local result
    result="$(printf '%s, ' "${parts[@]}")"
    printf '[%s]' "${result%, }"
  fi
}

# --- Config parsing ---

_w_config_file() {
  local root="$1"
  local cfg="$root/.wtconfig.toml"
  if [[ -f "$cfg" ]]; then
    printf '%s' "$cfg"
  else
    return 1
  fi
}

_w_config_get() {
  local root="$1" query="$2"
  local cfg
  cfg="$(_w_config_file "$root")" || return 1
  yq -p toml -oj -r "$query" "$cfg"
}

_w_resolve_path() {
  local root="$1" name="$2"
  local project parent template
  project="$(_w_project_name "$root")"
  parent="$(_w_parent_dir "$root")"
  template="$(_w_config_get "$root" '.path' 2>/dev/null)" || template=""
  # yq prints "null" for missing keys
  [[ "$template" == "null" || -z "$template" ]] && template="{parent}/{project}.{name}"
  template="${template//\{project\}/$project}"
  template="${template//\{name\}/$name}"
  template="${template//\{parent\}/$parent}"
  template="${template//\{home\}/$HOME}"
  printf '%s' "$template"
}

_w_build_env() {
  local root="$1" name="$2" slot="$3"
  local env_json
  env_json="$(_w_config_get "$root" '.env' 2>/dev/null)" || return 0
  [[ -z "$env_json" || "$env_json" == "null" ]] && return 0
  local project
  project="$(_w_project_name "$root")"
  printf '%s' "$env_json" | jq -r 'to_entries[] | "\(.key)\t\(.value)"' | while IFS=$'\t' read -r key val; do
    # {base:N} → N + slot
    if [[ "$val" =~ ^\{base:([0-9]+)\}$ ]]; then
      val=$(( ${BASH_REMATCH[1]} + slot ))
    fi
    val="${val//\{name\}/$name}"
    val="${val//\{project\}/$project}"
    printf '%s=%s\n' "$key" "$val"
  done
}

# --- Slot allocation ---

_w_project_id() {
  local root="$1"
  local resolved
  resolved="$(cd "$root" && pwd)"
  printf '%s' "${resolved//\//_}" | sed 's/^_//'
}

_w_state_dir() {
  local root="$1"
  local dir="$STATE_DIR/projects/$(_w_project_id "$root")"
  mkdir -p "$dir"
  printf '%s' "$dir"
}

_w_slots_file() {
  printf '%s' "$(_w_state_dir "$1")/slots.json"
}

_w_read_slots() {
  local file
  file="$(_w_slots_file "$1")"
  if [[ -f "$file" ]]; then
    cat "$file"
  else
    echo '{}'
  fi
}

_w_write_slots() {
  local root="$1" json="$2"
  printf '%s\n' "$json" > "$(_w_slots_file "$root")"
}

_w_slot_assign() {
  local name="$1" root="$2"
  local slots existing
  slots="$(_w_read_slots "$root")"
  # Already assigned? Return existing slot
  existing="$(printf '%s' "$slots" | jq -r --arg n "$name" '.[$n] // empty')"
  if [[ -n "$existing" ]]; then
    printf '%s' "$existing"
    return
  fi
  # Find lowest available slot >= 1
  local slot
  slot="$(printf '%s' "$slots" | jq '[.[] | tonumber] | . as $used | 1 | until(. as $s | $used | index($s) | not; . + 1)')"
  # Write updated slots
  local updated
  updated="$(printf '%s' "$slots" | jq --arg n "$name" --argjson s "$slot" '. + {($n): $s}')"
  _w_write_slots "$root" "$updated"
  printf '%s' "$slot"
}

_w_slot_free() {
  local name="$1" root="$2"
  local slots updated
  slots="$(_w_read_slots "$root")"
  updated="$(printf '%s' "$slots" | jq --arg n "$name" 'del(.[$n])')"
  _w_write_slots "$root" "$updated"
}

_w_slot_get() {
  local name="$1" root="$2"
  if [[ "$name" == "main" ]]; then
    printf '0'
    return
  fi
  local slots val
  slots="$(_w_read_slots "$root")"
  val="$(printf '%s' "$slots" | jq -r --arg n "$name" '.[$n] // empty')"
  printf '%s' "$val"
}

# --- Worktree creation ---

_w_create_worktree() {
  local name="$1" path="$2" root="$3"
  mkdir -p "$(dirname "$path")"
  local err
  if ! err="$(git -C "$root" worktree add -b "$name" "$path" main 2>&1)"; then
    if [[ "$err" == *"already exists"* ]]; then
      if ! err="$(git -C "$root" worktree add "$path" "$name" 2>&1)"; then
        echo "Failed to create worktree: $err" >&2
        exit 1
      fi
    else
      echo "Failed to create worktree: $err" >&2
      exit 1
    fi
  fi
}

_w_run_setup() {
  local path="$1" root="$2" name="$3"
  local commands
  commands="$(_w_config_get "$root" '.setup.commands[]' 2>/dev/null)" || return 0
  [[ -z "$commands" || "$commands" == "null" ]] && return 0
  while IFS= read -r cmd; do
    [[ -z "$cmd" ]] && continue
    echo "Running setup: $cmd" >&2
    if ! (cd "$path" && W_ROOT="$root" W_WORKTREE="$name" eval "$cmd"); then
      echo "Warning: setup command '$cmd' failed" >&2
    fi
  done <<< "$commands"
}

# --- Worktree name resolution ---

_w_current_worktree_name() {
  local root="$1"
  local cwd
  cwd="$(pwd)"
  _w_parse_worktrees "$root" | while IFS=$'\t' read -r wt_path branch sha state; do
    if [[ "$cwd" == "$wt_path"* ]]; then
      printf '%s' "${branch:-main}"
      return
    fi
  done
  printf 'main'
}

# --- Display formatting ---

_w_format_status() {
  local dirty="$1" count="$2"
  if [[ "$dirty" == "true" ]]; then
    local suffix="files changed"
    [[ "$count" -eq 1 ]] && suffix="file changed"
    printf '%s  %s' "$(_w_yellow "dirty")" "$(_w_dim "$count $suffix")"
  else
    _w_green "clean"
  fi
}

_w_env_status_line() {
  local name="$1" root="$2"
  local slot
  if [[ "$name" == "main" ]]; then
    slot=0
  else
    slot="$(_w_slot_get "$name" "$root")"
    [[ -z "$slot" ]] && return 0
  fi
  local env_lines
  env_lines="$(_w_build_env "$root" "$name" "$slot")" || return 0
  [[ -z "$env_lines" ]] && return 0
  # Show compact KEY=val pairs
  local parts=""
  while IFS='=' read -r key val; do
    [[ -n "$parts" ]] && parts="$parts "
    parts="$parts$key=$val"
  done <<< "$env_lines"
  printf '%s' "$parts"
}

# --- Subcommands ---

_w_cmd_version() {
  echo "w $VERSION"
}

_w_cmd_exit() {
  if [[ -n "${W_WORKTREE:-}" ]]; then
    echo "Type 'exit' to leave worktree '$W_WORKTREE'." >&2
  else
    echo "Not in a w subshell." >&2
  fi
}

_w_cmd_go() {
  local name="$1"
  shift
  local root path
  root="$(_w_find_root)"

  path="$(_w_resolve_path "$root" "$name")"

  # If extra args, delegate to run
  if [[ $# -gt 0 ]]; then
    _w_cmd_run "$name" "$@"
    return
  fi

  if [[ ! -d "$path" || ! -e "$path/.git" ]]; then
    echo "Creating worktree $name..." >&2
    _w_create_worktree "$name" "$path" "$root"
    _w_slot_assign "$name" "$root" > /dev/null
    _w_run_setup "$path" "$root" "$name"
  fi

  local slot
  slot="$(_w_slot_get "$name" "$root")"
  [[ -z "$slot" ]] && slot=0

  echo "→ $path" >&2
  _w_spawn_subshell "$path" "$root" "$name" "$slot"
}

_w_cmd_run() {
  local name="$1"
  shift
  local root path
  root="$(_w_find_root)"
  path="$(_w_resolve_path "$root" "$name")"
  if [[ ! -d "$path" || ! -e "$path/.git" ]]; then
    echo "Worktree $name does not exist" >&2
    exit 1
  fi
  local slot
  slot="$(_w_slot_get "$name" "$root")"
  [[ -z "$slot" ]] && slot=0
  local env_args=("W_WORKTREE=$name" "W_ROOT=$root" "W_PROJECT=$(_w_project_name "$root")")
  local env_lines
  env_lines="$(_w_build_env "$root" "$name" "$slot")"
  if [[ -n "$env_lines" ]]; then
    while IFS='=' read -r key val; do
      env_args+=("$key=$val")
    done <<< "$env_lines"
  fi
  (cd "$path" && env "${env_args[@]}" bash -c "$*")
}

_w_cmd_ls() {
  local root
  root="$(_w_find_root)"
  local current_path
  current_path="$(pwd)"

  _w_parse_worktrees "$root" | while IFS=$'\t' read -r wt_path branch sha state; do
    local name="${branch:-"(unknown)"}"
    [[ "$state" == "detached" && -z "$branch" ]] && name="(detached)"

    local is_current="false"
    [[ "$current_path" == "$wt_path"* ]] && is_current="true"

    local marker=" "
    local display_name="$name"
    if [[ "$is_current" == "true" ]]; then
      marker="$(_w_bold_green '*')"
      display_name="$(_w_bold "$name")"
    fi

    local dirty="false"
    local count=0
    if _w_worktree_dirty "$wt_path"; then
      dirty="true"
      count="$(_w_worktree_dirty_count "$wt_path")"
    fi
    local status_str
    status_str="$(_w_format_status "$dirty" "$count")"

    local ab
    ab="$(_w_worktree_ahead_behind "$wt_path")"
    [[ -n "$ab" ]] && ab="$(_w_cyan "$ab")"

    local env_status
    env_status="$(_w_env_status_line "$name" "$root")"

    # Build line: marker  name(padded)  status  [ahead/behind]  [env]
    local line
    line="$(printf '%s  %-15s  %s' "$marker" "$display_name" "$status_str")"
    [[ -n "$ab" ]] && line="$line  $ab"
    [[ -n "$env_status" ]] && line="$line  $(_w_dim "$env_status")"
    echo "$line"
  done
}

_w_cmd_status() {
  local root
  root="$(_w_find_root)"
  local current_path
  current_path="$(pwd)"
  local proj
  proj="$(_w_project_name "$root")"

  # Count worktrees
  local wt_data
  wt_data="$(_w_parse_worktrees "$root")"
  local wt_count
  wt_count="$(echo "$wt_data" | wc -l | tr -d ' ')"
  local plural="s"
  [[ "$wt_count" -eq 1 ]] && plural=""

  echo "$(_w_bold "$proj") — $wt_count worktree$plural"
  echo ""

  echo "$wt_data" | while IFS=$'\t' read -r wt_path branch sha state; do
    local name="${branch:-"(unknown)"}"
    [[ "$state" == "detached" && -z "$branch" ]] && name="(detached)"

    local is_current="false"
    [[ "$current_path" == "$wt_path"* ]] && is_current="true"

    local marker=" "
    local display_name="$name"
    if [[ "$is_current" == "true" ]]; then
      marker="$(_w_bold_green '*')"
      display_name="$(_w_bold "$name")"
    fi

    local dirty="false"
    local count=0
    if _w_worktree_dirty "$wt_path"; then
      dirty="true"
      count="$(_w_worktree_dirty_count "$wt_path")"
    fi
    local status_str
    status_str="$(_w_format_status "$dirty" "$count")"

    local ab
    ab="$(_w_worktree_ahead_behind "$wt_path")"
    [[ -n "$ab" ]] && ab="$(_w_cyan "$ab")"

    local env_status
    env_status="$(_w_env_status_line "$name" "$root")"

    local line
    line="$(printf '%s  %-15s  %s' "$marker" "$display_name" "$status_str")"
    [[ -n "$ab" ]] && line="$line  $ab"
    echo "$line"

    # Show env var details
    if [[ -n "$env_status" ]]; then
      echo "              $(_w_dim "$env_status")"
    fi
  done
}

_w_cmd_rm() {
  local name="" force="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force="true"; shift ;;
      *)       name="$1"; shift ;;
    esac
  done

  [[ -z "$name" ]] && { echo "Usage: w rm <name> [--force]" >&2; exit 1; }

  if [[ "${W_WORKTREE:-}" == "$name" ]]; then
    echo "Cannot remove worktree '$name' while inside it. Type 'exit' first." >&2
    exit 1
  fi

  local root
  root="$(_w_find_root)"

  # Check for unmerged commits unless --force
  if [[ "$force" != "true" ]]; then
    local unmerged
    unmerged="$(git -C "$root" log --oneline "main..$name" 2>/dev/null)" || unmerged=""
    if [[ -n "$unmerged" ]]; then
      echo "Branch $name has unmerged commits (use --force to override)" >&2
      exit 1
    fi
  fi

  # Find worktree path by branch name
  local wt_path=""
  while IFS=$'\t' read -r path branch sha state; do
    if [[ "$branch" == "$name" ]]; then
      wt_path="$path"
      break
    fi
  done <<< "$(_w_parse_worktrees "$root")"

  [[ -z "$wt_path" ]] && { echo "Worktree for branch '$name' not found" >&2; exit 1; }

  echo "Removing worktree $name..." >&2
  local rm_args=("git" "-C" "$root" "worktree" "remove")
  [[ "$force" == "true" ]] && rm_args+=("--force")
  rm_args+=("$wt_path")

  local err
  if ! err="$("${rm_args[@]}" 2>&1)"; then
    echo "Failed to remove worktree: $err" >&2
    exit 1
  fi

  _w_slot_free "$name" "$root"
  echo "Done." >&2
}

_w_cmd_init() {
  local root
  root="$(_w_find_main_worktree)"
  local cfg="$root/.wtconfig.toml"
  if [[ -f "$cfg" ]]; then
    echo ".wtconfig.toml already exists in $root" >&2
    exit 1
  fi
  cat > "$cfg" <<'TOML'
# Worktree directory layout (default: sibling directories)
# Available tokens: {project}, {name}, {parent}, {home}
# Examples:
#   "{parent}/{project}.worktrees/{name}"  — subdirectory of project
#   "{home}/worktrees/{project}/{name}"    — global worktree directory
path = "{parent}/{project}.{name}"

# Setup commands run in the worktree directory after creation.
# Available env vars: $W_ROOT (base repo path), $W_WORKTREE (branch name).
[setup]
commands = []
# commands = ["npm install", "cp $W_ROOT/.env .env"]

# Environment variables exported into the worktree subshell.
# Use {base:N} for port allocation (N + worktree slot).
# Use {name} for worktree name, {project} for project name.
#
# [env]
# PORT = "{base:3000}"
# API_PORT = "{base:8080}"
# DATABASE_URL = "postgres://localhost/myapp_{name}"
TOML
  echo "Created $cfg" >&2
}

_w_cmd_help() {
  cat >&2 <<'EOF'
Usage: w <name>          Enter worktree (spawns subshell)
       w <name> <cmd>    Run command in worktree
       w init            Create .wtconfig.toml in repo root
       w ls              List worktrees
       w status          Project dashboard
       w rm <name>       Remove worktree
       w --version       Print version
       w --help          Show this help
EOF
}

# --- Main router ---

main() {
  local cmd="${1:-}"
  # These work anywhere — no repo required
  case "$cmd" in
    --version) _w_cmd_version; return ;;
    --help|"") _w_cmd_help; return ;;
  esac
  # Everything below requires a git repo
  case "$cmd" in
    init)      shift; _w_cmd_init "$@" ;;
    ls)        shift; _w_cmd_ls "$@" ;;
    rm)        shift; _w_cmd_rm "$@" ;;
    exit)      shift; _w_cmd_exit "$@" ;;
    status)    shift; _w_cmd_status "$@" ;;
    *)         _w_cmd_go "$@" ;;
  esac
}

# Allow sourcing for tests: `source bin/w --source-only`
if [[ "${1:-}" != "--source-only" ]]; then
  main "$@"
fi
