#!/usr/bin/env bash
set -euo pipefail

VERSION="0.0.1"
STATE_DIR="${W_STATE_DIR:-${HOME}/.local/state/w}"

# --- Project discovery ---

_w_find_root() {
  git rev-parse --show-toplevel 2>/dev/null || { echo "Not inside a git repository" >&2; exit 1; }
}

_w_project_name() {
  basename "$1"
}

_w_parent_dir() {
  dirname "$1"
}

_w_find_main_worktree() {
  local output
  output=$(git worktree list 2>/dev/null) || { echo "Not inside a git repository" >&2; exit 1; }
  echo "$output" | head -1 | awk '{print $1}'
}

# --- cd-target ---

_w_cd_target() {
  mkdir -p "$STATE_DIR"
  printf '%s' "$1" > "$STATE_DIR/cd-target"
}

# --- Color helpers ---

_w_use_color() {
  [[ -z "${NO_COLOR:-}" ]] && [[ -t 2 ]]
}

_w_color() {
  local code="$1" text="$2"
  if _w_use_color; then
    printf '%b%s\e[0m' "$code" "$text"
  else
    printf '%s' "$text"
  fi
}

_w_bold()       { _w_color '\e[1m' "$1"; }
_w_green()      { _w_color '\e[32m' "$1"; }
_w_red()        { _w_color '\e[31m' "$1"; }
_w_yellow()     { _w_color '\e[33m' "$1"; }
_w_cyan()       { _w_color '\e[36m' "$1"; }
_w_dim()        { _w_color '\e[2m' "$1"; }
_w_bold_green() { _w_color '\e[1m\e[32m' "$1"; }

# --- Worktree parsing ---

_w_parse_worktrees() {
  local root="$1"
  git -C "$root" worktree list --porcelain | awk '
    /^worktree / { path = substr($0, 10) }
    /^HEAD /     { sha = $2 }
    /^branch /   { branch = $2; sub(/^refs\/heads\//, "", branch) }
    /^bare$/     { state = "bare" }
    /^detached$/ { state = "detached" }
    /^$/         {
      if (path != "") {
        if (state == "") state = "normal"
        if (branch == "") branch = ""
        printf "%s\t%s\t%s\t%s\n", path, branch, sha, state
        path = ""; branch = ""; sha = ""; state = ""
      }
    }
    END {
      if (path != "") {
        if (state == "") state = "normal"
        printf "%s\t%s\t%s\t%s\n", path, branch, sha, state
      }
    }
  '
}

_w_worktree_dirty() {
  local path="$1"
  [[ -n "$(git -C "$path" status --porcelain 2>/dev/null)" ]]
}

_w_worktree_dirty_count() {
  local path="$1"
  local output
  output="$(git -C "$path" status --porcelain 2>/dev/null)" || { echo 0; return; }
  if [[ -z "$output" ]]; then
    echo 0
  else
    echo "$output" | wc -l | tr -d ' '
  fi
}

_w_worktree_ahead_behind() {
  local path="$1"
  local output
  output="$(git -C "$path" rev-list --left-right --count HEAD...@{upstream} 2>/dev/null)" || { echo ""; return; }
  local ahead behind
  ahead="$(echo "$output" | awk '{print $1}')"
  behind="$(echo "$output" | awk '{print $2}')"
  local parts=()
  [[ "$ahead" -gt 0 ]] 2>/dev/null && parts+=("ahead $ahead")
  [[ "$behind" -gt 0 ]] 2>/dev/null && parts+=("behind $behind")
  if [[ ${#parts[@]} -gt 0 ]]; then
    local result
    result="$(printf '%s, ' "${parts[@]}")"
    printf '[%s]' "${result%, }"
  fi
}

# --- Config parsing ---

_w_config_file() {
  local root="$1"
  local cfg="$root/.wtconfig.toml"
  if [[ -f "$cfg" ]]; then
    printf '%s' "$cfg"
  else
    return 1
  fi
}

_w_config_get() {
  local root="$1" query="$2"
  local cfg
  cfg="$(_w_config_file "$root")" || return 1
  tomlq -r "$query" "$cfg"
}

_w_resolve_path() {
  local root="$1" name="$2"
  local project parent template
  project="$(_w_project_name "$root")"
  parent="$(_w_parent_dir "$root")"
  template="$(_w_config_get "$root" '.path' 2>/dev/null)" || template=""
  # yq prints "null" for missing keys
  [[ "$template" == "null" || -z "$template" ]] && template="{parent}/{project}.{name}"
  template="${template//\{project\}/$project}"
  template="${template//\{name\}/$name}"
  template="${template//\{parent\}/$parent}"
  template="${template//\{home\}/$HOME}"
  printf '%s' "$template"
}

# --- Slot allocation ---

_w_project_id() {
  local root="$1"
  local resolved
  resolved="$(cd "$root" && pwd)"
  printf '%s' "${resolved//\//_}" | sed 's/^_//'
}

_w_state_dir() {
  local root="$1"
  local dir="$STATE_DIR/projects/$(_w_project_id "$root")"
  mkdir -p "$dir"
  printf '%s' "$dir"
}

_w_slots_file() {
  printf '%s' "$(_w_state_dir "$1")/slots.json"
}

_w_read_slots() {
  local file
  file="$(_w_slots_file "$1")"
  if [[ -f "$file" ]]; then
    cat "$file"
  else
    echo '{}'
  fi
}

_w_write_slots() {
  local root="$1" json="$2"
  printf '%s\n' "$json" > "$(_w_slots_file "$root")"
}

_w_slot_assign() {
  local name="$1" root="$2"
  local slots existing
  slots="$(_w_read_slots "$root")"
  # Already assigned? Return existing slot
  existing="$(printf '%s' "$slots" | jq -r --arg n "$name" '.[$n] // empty')"
  if [[ -n "$existing" ]]; then
    printf '%s' "$existing"
    return
  fi
  # Find lowest available slot >= 1
  local slot
  slot="$(printf '%s' "$slots" | jq '[.[] | tonumber] | . as $used | 1 | until(. as $s | $used | index($s) | not; . + 1)')"
  # Write updated slots
  local updated
  updated="$(printf '%s' "$slots" | jq --arg n "$name" --argjson s "$slot" '. + {($n): $s}')"
  _w_write_slots "$root" "$updated"
  printf '%s' "$slot"
}

_w_slot_free() {
  local name="$1" root="$2"
  local slots updated
  slots="$(_w_read_slots "$root")"
  updated="$(printf '%s' "$slots" | jq --arg n "$name" 'del(.[$n])')"
  _w_write_slots "$root" "$updated"
}

_w_slot_get() {
  local name="$1" root="$2"
  if [[ "$name" == "main" ]]; then
    printf '0'
    return
  fi
  local slots val
  slots="$(_w_read_slots "$root")"
  val="$(printf '%s' "$slots" | jq -r --arg n "$name" '.[$n] // empty')"
  printf '%s' "$val"
}

# --- Worktree creation ---

_w_create_worktree() {
  local name="$1" path="$2" root="$3"
  mkdir -p "$(dirname "$path")"
  local err
  if ! err="$(git -C "$root" worktree add -b "$name" "$path" main 2>&1)"; then
    if [[ "$err" == *"already exists"* ]]; then
      if ! err="$(git -C "$root" worktree add "$path" "$name" 2>&1)"; then
        echo "Failed to create worktree: $err" >&2
        exit 1
      fi
    else
      echo "Failed to create worktree: $err" >&2
      exit 1
    fi
  fi
}

_w_run_setup() {
  local path="$1" root="$2"
  local commands
  commands="$(_w_config_get "$root" '.setup.commands[]' 2>/dev/null)" || return 0
  [[ -z "$commands" || "$commands" == "null" ]] && return 0
  while IFS= read -r cmd; do
    [[ -z "$cmd" ]] && continue
    echo "Running setup: $cmd" >&2
    if ! (cd "$path" && eval "$cmd"); then
      echo "Warning: setup command '$cmd' failed" >&2
    fi
  done <<< "$commands"
}

# --- Ports (read-only helpers for ls/status) ---

_w_ports_file() {
  local root="$1"
  printf '%s' "$(_w_state_dir "$root")/ports.json"
}

_w_read_ports() {
  local root="$1"
  local file
  file="$(_w_ports_file "$root")"
  if [[ -f "$file" ]]; then
    cat "$file"
  else
    echo '{}'
  fi
}

# --- Display formatting ---

_w_format_status() {
  local dirty="$1" count="$2"
  if [[ "$dirty" == "true" ]]; then
    local suffix="files changed"
    [[ "$count" -eq 1 ]] && suffix="file changed"
    printf '%s  %s' "$(_w_yellow "dirty")" "$(_w_dim "$count $suffix")"
  else
    _w_green "clean"
  fi
}

_w_server_status_line() {
  local name="$1" root="$2"
  local ports_json
  ports_json="$(_w_read_ports "$root")"
  local entries
  entries="$(printf '%s' "$ports_json" | jq -r --arg n "$name" '
    .[$n].servers // {} | to_entries[] | "\(.value.port)\t\(.value.pid)"
  ' 2>/dev/null)" || return 0
  [[ -n "$entries" ]] || return 0
  local live_ports=""
  while IFS=$'\t' read -r port pid; do
    if [[ -n "$pid" && -d "/proc/$pid" ]]; then
      [[ -n "$live_ports" ]] && live_ports="$live_ports,"
      live_ports="$live_ports:$port"
    fi
  done <<< "$entries"
  [[ -n "$live_ports" ]] || return 0
  printf '● server running %s' "$live_ports"
}

_w_server_status_block() {
  local name="$1" root="$2"
  local ports_json
  ports_json="$(_w_read_ports "$root")"
  local has_entry
  has_entry="$(printf '%s' "$ports_json" | jq -r --arg n "$name" 'has($n) | tostring')"
  [[ "$has_entry" == "true" ]] || return 0
  # Output sorted server entries: name\tport\tpid\talive
  printf '%s' "$ports_json" | jq -r --arg n "$name" '
    .[$n].servers // {} | to_entries | sort_by(.key)[] |
    "\(.key)\t\(.value.port)\t\(.value.pid)"
  ' | while IFS=$'\t' read -r srv port pid; do
    local alive="false"
    if [[ -n "$pid" && -d "/proc/$pid" ]]; then
      alive="true"
    fi
    printf '%s\t%s\t%s\t%s\n' "$srv" "$port" "$pid" "$alive"
  done
}

# --- Subcommands ---

_w_cmd_version() {
  echo "w $VERSION"
}

_w_cmd_exit() {
  local main_wt
  main_wt="$(_w_find_main_worktree)"
  echo "→ $main_wt" >&2
  _w_cd_target "$main_wt"
}

_w_cmd_go() {
  local name="$1"
  shift
  local root path
  root="$(_w_find_root)"

  path="$(_w_resolve_path "$root" "$name")"

  # If extra args, delegate to run
  if [[ $# -gt 0 ]]; then
    _w_cmd_run "$name" "$@"
    return
  fi

  if [[ -d "$path" && -e "$path/.git" ]]; then
    # Existing worktree — just cd
    echo "→ $path" >&2
    _w_cd_target "$path"
  else
    # Create new worktree
    echo "Creating worktree $name..." >&2
    _w_create_worktree "$name" "$path" "$root"
    _w_slot_assign "$name" "$root" > /dev/null
    _w_run_setup "$path" "$root"
    echo "→ $path" >&2
    _w_cd_target "$path"
  fi
}

_w_cmd_run() {
  local name="$1"
  shift
  local root path
  root="$(_w_find_root)"
  path="$(_w_resolve_path "$root" "$name")"
  if [[ ! -d "$path" || ! -e "$path/.git" ]]; then
    echo "Worktree $name does not exist" >&2
    exit 1
  fi
  (cd "$path" && eval "$@")
}

_w_cmd_ls() {
  local root
  root="$(_w_find_root)"
  local current_path
  current_path="$(pwd)"

  _w_parse_worktrees "$root" | while IFS=$'\t' read -r wt_path branch sha state; do
    local name="${branch:-"(unknown)"}"
    [[ "$state" == "detached" && -z "$branch" ]] && name="(detached)"

    local is_current="false"
    [[ "$current_path" == "$wt_path"* ]] && is_current="true"

    local marker=" "
    local display_name="$name"
    if [[ "$is_current" == "true" ]]; then
      marker="$(_w_bold_green '*')"
      display_name="$(_w_bold "$name")"
    fi

    local dirty="false"
    local count=0
    if _w_worktree_dirty "$wt_path"; then
      dirty="true"
      count="$(_w_worktree_dirty_count "$wt_path")"
    fi
    local status_str
    status_str="$(_w_format_status "$dirty" "$count")"

    local ab
    ab="$(_w_worktree_ahead_behind "$wt_path")"
    [[ -n "$ab" ]] && ab="$(_w_cyan "$ab")"

    local srv_status
    srv_status="$(_w_server_status_line "$name" "$root")"

    # Build line: marker  name(padded)  status  [ahead/behind]  [server]
    local line
    line="$(printf '%s  %-15s  %s' "$marker" "$display_name" "$status_str")"
    [[ -n "$ab" ]] && line="$line  $ab"
    if [[ -n "$srv_status" ]]; then
      local formatted_srv
      formatted_srv="$(_w_green "●") ${srv_status#● }"
      line="$line  $formatted_srv"
    fi
    echo "$line"
  done
}

_w_cmd_status() {
  local root
  root="$(_w_find_root)"
  local current_path
  current_path="$(pwd)"
  local proj
  proj="$(_w_project_name "$root")"

  # Count worktrees
  local wt_data
  wt_data="$(_w_parse_worktrees "$root")"
  local wt_count
  wt_count="$(echo "$wt_data" | wc -l | tr -d ' ')"
  local plural="s"
  [[ "$wt_count" -eq 1 ]] && plural=""

  echo "$(_w_bold "$proj") — $wt_count worktree$plural"
  echo ""

  echo "$wt_data" | while IFS=$'\t' read -r wt_path branch sha state; do
    local name="${branch:-"(unknown)"}"
    [[ "$state" == "detached" && -z "$branch" ]] && name="(detached)"

    local is_current="false"
    [[ "$current_path" == "$wt_path"* ]] && is_current="true"

    local marker=" "
    local display_name="$name"
    if [[ "$is_current" == "true" ]]; then
      marker="$(_w_bold_green '*')"
      display_name="$(_w_bold "$name")"
    fi

    local dirty="false"
    local count=0
    if _w_worktree_dirty "$wt_path"; then
      dirty="true"
      count="$(_w_worktree_dirty_count "$wt_path")"
    fi
    local status_str
    status_str="$(_w_format_status "$dirty" "$count")"

    local ab
    ab="$(_w_worktree_ahead_behind "$wt_path")"
    [[ -n "$ab" ]] && ab="$(_w_cyan "$ab")"

    local line
    line="$(printf '%s  %-15s  %s' "$marker" "$display_name" "$status_str")"
    [[ -n "$ab" ]] && line="$line  $ab"
    echo "$line"

    # Show server details
    local srv_block
    srv_block="$(_w_server_status_block "$name" "$root")"
    if [[ -n "$srv_block" ]]; then
      local total
      total="$(echo "$srv_block" | wc -l)"
      local i=0
      echo "$srv_block" | while IFS=$'\t' read -r srv port pid alive; do
        i=$((i + 1))
        local connector="├"
        [[ "$i" -eq "$total" ]] && connector="└"
        local srv_status_str
        if [[ "$alive" == "true" ]]; then
          srv_status_str="$(_w_green "pid $pid")"
        else
          srv_status_str="$(_w_red "stopped")"
        fi
        echo "              $connector $srv  $(_w_cyan ":$port")  ($srv_status_str)"
      done
    fi
  done
}

_w_cmd_help() {
  cat >&2 <<'EOF'
Usage: w <name>          Switch to (or create) worktree
       w <name> <cmd>    Run command in worktree
       w ls              List worktrees
       w status          Project dashboard
       w rm <name>       Remove worktree
       w exit            Return to main worktree
       w serve [name]    Start dev servers
       w stop [name]     Stop dev servers
       w --version       Print version
       w --help          Show this help
EOF
}

# --- Main router ---

main() {
  local cmd="${1:-}"
  case "$cmd" in
    ls)        shift; _w_cmd_ls "$@" ;;
    rm)        shift; _w_cmd_rm "$@" ;;
    exit)      shift; _w_cmd_exit "$@" ;;
    status)    shift; _w_cmd_status "$@" ;;
    serve)     shift; _w_cmd_serve "$@" ;;
    stop)      shift; _w_cmd_stop "$@" ;;
    --version) _w_cmd_version ;;
    --help)    _w_cmd_help ;;
    "")        _w_cmd_help ;;
    *)         _w_cmd_go "$@" ;;
  esac
}

# Allow sourcing for tests: `source bin/w --source-only`
if [[ "${1:-}" != "--source-only" ]]; then
  main "$@"
fi
