#!/usr/bin/env raku
use W::Raku;
use W::Project;
use W::Worktree;

multi MAIN('ls') {
    require W::Display <&bold-green &bold &format-status &format-ahead-behind &format-server-status>;
    require W::Server <&read-ports &server-status-line>;

    my $root = find-repo-root();
    my @worktrees = list-worktrees(repo-root => $root);
    my $current-path = $*CWD.Str;
    my %ports = read-ports($root);

    for @worktrees -> %wt {
        my $path = %wt<path>.IO;
        my $name = %wt<branch> // (%wt<detached>:exists ?? '(detached)' !! '(unknown)');
        my $is-current = $current-path.starts-with(%wt<path>);
        my $marker = $is-current ?? bold-green('*') !! ' ';
        my $display-name = $is-current ?? bold($name) !! $name;
        my $dirty = worktree-dirty(path => $path);
        my $count = $dirty ?? worktree-dirty-count(path => $path) !! 0;
        my $status = format-status($dirty, $count);
        my $ab = format-ahead-behind(worktree-ahead-behind(path => $path));
        my @cols = $marker, sprintf('%-15s', $display-name), $status;
        @cols.push($ab) if $ab;
        # Append server status if running
        my $srv-status = server-status-line($name, %ports);
        @cols.push(format-server-status($srv-status)) if $srv-status;
        say @cols.join('  ');
    }
}

multi MAIN('rm', Str $name, Bool :$force) {
    require W::Server <&stop-servers>;
    require W::Slots <&free-slot>;

    my $root = find-repo-root();
    stop-servers(:$name, repo-root => $root);
    note "Removing worktree $name...";
    remove-worktree(:$name, repo-root => $root, :$force);
    free-slot(:$name, repo-root => $root);
    note "Done.";
}

multi MAIN('exit') {
    require W::Nav <&write-cd-target>;

    my $main = find-main-worktree();
    note "→ $main";
    write-cd-target($main);
}

multi MAIN('status') {
    require W::Display <&bold &bold-green &green &red &cyan &format-status &format-ahead-behind>;
    require W::Server <&read-ports &server-status-block>;

    my $root = find-repo-root();
    my @worktrees = list-worktrees(repo-root => $root);
    my $current-path = $*CWD.Str;
    my %ports = read-ports($root);
    my $proj = project-name($root);

    say bold("$proj") ~ " — {@worktrees.elems} worktree{@worktrees.elems == 1 ?? '' !! 's'}";
    say '';

    for @worktrees -> %wt {
        my $path = %wt<path>.IO;
        my $name = %wt<branch> // (%wt<detached>:exists ?? '(detached)' !! '(unknown)');
        my $is-current = $current-path.starts-with(%wt<path>);
        my $marker = $is-current ?? bold-green('*') !! ' ';
        my $display-name = $is-current ?? bold($name) !! $name;
        my $dirty = worktree-dirty(path => $path);
        my $count = $dirty ?? worktree-dirty-count(path => $path) !! 0;
        my $status = format-status($dirty, $count);
        my $ab = format-ahead-behind(worktree-ahead-behind(path => $path));
        my @cols = $marker, sprintf('%-15s', $display-name), $status;
        @cols.push($ab) if $ab;
        say @cols.join('  ');

        # Show server details
        my @srv = server-status-block($name, %ports);
        for @srv.kv -> $i, $s {
            my $connector = $i == @srv.elems - 1 ?? '└' !! '├';
            my $srv-status = $s<alive> ?? green("pid {$s<status>.subst('pid ', '')}") !! red("stopped");
            say "              $connector {$s<name>}  " ~ cyan(":{$s<port>}") ~ "  ($srv-status)";
        }
    }
}

multi MAIN('serve', Str $name?, Str :$only) {
    require W::Config <&load-config>;
    require W::Server <&start-servers>;

    my $root = find-repo-root();
    my %config = load-config($root);
    my $wt-name = $name // do {
        my @wts = list-worktrees(repo-root => $root);
        my $cwd = $*CWD.Str;
        my $current = @wts.first({ $cwd.starts-with(.<path>) });
        $current ?? ($current<branch> // 'main') !! 'main';
    };
    start-servers(:name($wt-name), repo-root => $root, :%config, :$only);
}

multi MAIN('stop', Str $name?) {
    require W::Server <&stop-servers>;

    my $root = find-repo-root();
    my $wt-name = $name // do {
        my @wts = list-worktrees(repo-root => $root);
        my $cwd = $*CWD.Str;
        my $current = @wts.first({ $cwd.starts-with(.<path>) });
        $current ?? ($current<branch> // 'main') !! 'main';
    };
    stop-servers(:name($wt-name), repo-root => $root);
}

multi MAIN(Str $name, *@cmd) {
    require W::Config <&load-config>;
    require W::Nav <&write-cd-target>;

    if @cmd.elems {
        my $root = find-repo-root();
        my %config = load-config($root);
        my $path = resolve-worktree-path(
            parent   => parent-dir($root),
            project  => project-name($root),
            name     => $name,
            template => %config<path> // Str,
        );
        die "Worktree $name does not exist" unless worktree-exists(:$path);
        my $proc = run 'sh', '-c', @cmd.join(' '), :cwd($path.Str);
        exit $proc.exitcode;
    } else {
        my $root = find-repo-root();
        my %config = load-config($root);
        my $path = resolve-worktree-path(
            parent   => parent-dir($root),
            project  => project-name($root),
            name     => $name,
            template => %config<path> // Str,
        );

        my $is-new = !worktree-exists(:$path);
        if $is-new {
            require W::Slots <&assign-slot>;
            require W::Setup <&run-setup>;

            note "Creating worktree $name...";
            create-worktree(:$name, :$path, :repo-root($root));
            assign-slot(:$name, repo-root => $root);

            my @setup-cmds = |(%config<setup><commands> // []);
            if @setup-cmds {
                run-setup(worktree-path => $path, commands => @setup-cmds);
            }
        }

        note "→ $path";
        write-cd-target($path);
    }
}

multi MAIN(Bool :$version!) {
    say "w-raku {W::Raku::VERSION}";
}
